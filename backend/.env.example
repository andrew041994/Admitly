APP_NAME=Admitly API
ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/admitly

MMG_ENABLED=false
MMG_PROVIDER_MODE=mock
MMG_BASE_URL=
MMG_MERCHANT_ID=
MMG_API_KEY=
MMG_API_SECRET=
MMG_CALLBACK_URL=
MMG_RETURN_URL_SUCCESS=
MMG_RETURN_URL_CANCEL=
MMG_REQUEST_TIMEOUT_SECONDS=10
MMG_AGENT_AUTO_VERIFY_ENABLED=true
MMG_AGENT_MANUAL_FALLBACK_ENABLED=true

EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=noop
EMAIL_FROM_ADDRESS=
PUSH_NOTIFICATIONS_ENABLED=false
PUSH_PROVIDER=noop
TICKET_PUBLIC_BASE_URL=https://admitly.app
JWT_SECRET=dev-change-me
JWT_ACCESS_TOKEN_EXP_MINUTES=15
JWT_REFRESH_TOKEN_EXP_DAYS=30
VERIFICATION_TOKEN_EXP_HOURS=24
PASSWORD_RESET_TOKEN_EXP_MINUTES=60
