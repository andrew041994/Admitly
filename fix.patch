+def test_dispute_creation_uniqueness_and_resolve_with_refund(db_session: Session) -> None:
+    data = _seed(db_session)
+
+    dispute = submit_dispute(
+        db_session,
+        user_id=data["buyer"].id,
+        order_id=data["paid_order"].id,
